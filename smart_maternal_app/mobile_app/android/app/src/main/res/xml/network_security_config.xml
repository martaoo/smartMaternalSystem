<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTP to local Nest during development (emulator, LAN IP, localhost). Use HTTPS in production. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
