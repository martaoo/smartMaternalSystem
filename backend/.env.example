# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/maternal-health

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-here

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (Gmail SMTP — FREE) ─────────────────────────────────────────────────
# 1. Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# 2. Create an App Password for "Mail"
# 3. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── SMS — Africa's Talking (FREE sandbox) ────────────────────────────────────
# 1. Sign up at https://africastalking.com
# 2. Use username "sandbox" and the API key from your sandbox dashboard
# 3. Register test phone numbers in the AT sandbox simulator
AT_USERNAME=sandbox
AT_API_KEY=your-sandbox-api-key-here
# AT_SENDER_ID=SmartMH   # Optional — leave blank for sandbox
